{
  "crons": [
    {
      "path": "/api/plaid/automatic-sync",
      "schedule": "24 22 * * *"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/_expo/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/static-build/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/:page(login|setup|bills|monthly|flo|transactions|more)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/setup",
      "destination": "/index.html"
    },
    {
      "source": "/bills",
      "destination": "/index.html"
    },
    {
      "source": "/monthly",
      "destination": "/index.html"
    },
    {
      "source": "/flo",
      "destination": "/index.html"
    },
    {
      "source": "/transactions",
      "destination": "/index.html"
    },
    {
      "source": "/more",
      "destination": "/index.html"
    }
  ]
}
