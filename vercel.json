{
  "crons": [
    {
      "path": "/api/plaid/automatic-sync",
      "schedule": "24 22 * * *"
    },
    {
      "path": "/api/notifications/overdue-bills",
      "schedule": "15 14 * * *"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/_expo/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/static-build/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/:page(login|legal|setup|bills|monthly|flo|transactions|more)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/notifications/:notificationAction(config|overdue-bills|preferences|subscription|test)",
      "destination": "/api/notifications?notificationAction=:notificationAction"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
