{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/_expo/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/login", "destination": "/index.html" },
    { "source": "/bills", "destination": "/index.html" },
    { "source": "/monthly", "destination": "/index.html" },
    { "source": "/transactions", "destination": "/index.html" },
    { "source": "/more", "destination": "/index.html" }
  ]
}
